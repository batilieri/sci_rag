{
  "uid": "sci-rag-api",
  "title": "SCI RAG API",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "HTTP requests",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "targets": [
        {
          "expr": "sum(rate(rag_http_requests_total[5m]))",
          "legendFormat": "rps"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency p95",
      "gridPos": {"x": 6, "y": 0, "w": 9, "h": 4},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "{{path}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Errors",
      "gridPos": {"x": 15, "y": 0, "w": 9, "h": 4},
      "targets": [
        {
          "expr": "sum(rate(rag_http_requests_total{status=~\"5..\"}[5m])) by (path)",
          "legendFormat": "{{path}}"
        }
      ]
    }
  ]
}
