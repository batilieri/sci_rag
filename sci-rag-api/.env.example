# ===========================================
# SCI RAG API — environment configuration
# Copy to .env and fill before running
# ===========================================

# --- App ---
APP_ENV=production
APP_NAME=sci-rag-api
APP_VERSION=0.1.0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=4
APP_LOG_LEVEL=INFO
APP_DEBUG_RESPONSES=false

# --- Auth ---
# Master API key auto-bootstrapped on first start (used by SCI).
# Override on first deploy; the script generate_api_key.py is the canonical way.
SCI_API_KEY=
WEBHOOK_SECRET=change-me-32bytes-min
WEBHOOK_SCI_URL=https://sci.example.com/webhooks/rag

# --- Postgres ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=rag
POSTGRES_USER=rag
POSTGRES_PASSWORD=change-me

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- Qdrant ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=change-me
QDRANT_COLLECTION=sci_faq_ecd_ecf

# --- Cloudflare R2 (primary object storage) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=rag-images
R2_PUBLIC_BASE_URL=
R2_PRESIGNED_URL_TTL_SECONDS=3600

# --- MinIO (dev/local fallback only; activated via compose profile=local-storage) ---
MINIO_ENDPOINT=http://minio:9000
MINIO_USER=minio
MINIO_PASS=minio12345
MINIO_BUCKET=rag-images-dev

# --- LLM providers ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# --- Embeddings ---
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=8
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# --- RAG thresholds ---
MIN_SCORE_TOP_CHUNK=0.65
MIN_CONFIANCA_RESPOSTA=0.70
GREY_ZONE_LOW=0.65
GREY_ZONE_HIGH=0.80
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5
QUERY_REWRITE_VARIANTS=3

# --- Cache TTL (seconds) ---
CACHE_TTL_HIGH=86400      # >= 0.90
CACHE_TTL_MEDIUM=21600    # 0.70 - 0.90

# --- Rate limiting ---
RATE_LIMIT_QUERY=60/minute
RATE_LIMIT_INGEST=5/minute
RATE_LIMIT_FEEDBACK=120/minute

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Observability ---
PROMETHEUS_ENABLED=true
GRAFANA_PASSWORD=admin
